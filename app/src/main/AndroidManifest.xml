<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ==================== PERMISSIONS ==================== -->

    <!-- Allows the app to access the internet - needed for Firebase and Cloudinary -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Allows access to images on Android 12 and below -->
    <!-- maxSdkVersion=32 means this only applies up to Android 12 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Allows access to images on Android 13 and above -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Allows the app to use the phone's camera -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Allows the app to send notifications - required on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Allows the app to reschedule alarms after phone restart -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Allows the app to schedule exact alarms for the daily reminder -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Camera is optional - app still works on devices without a camera -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- ==================== APPLICATION ==================== -->

    <application
        android:name=".AppInitializer"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EnglishKingdom">

        <!-- ==================== ACTIVITIES ==================== -->

        <!-- Splash screen - the first screen shown when the app opens -->
        <activity
            android:name=".Activities.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <!-- Marks this as the entry point of the app -->
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login screen -->
        <activity
            android:name=".Activities.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Register screen -->
        <activity
            android:name=".Activities.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Home screen -->
        <activity
            android:name=".Activities.HomeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Learn screen - configChanges prevents restart when camera opens -->
        <activity
            android:name=".Activities.LearnActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Words screen - shows words inside a category -->
        <activity
            android:name=".Activities.WordsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Profile screen - shows user stats and kingdom card -->
        <activity
            android:name=".Activities.ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- How to Play screen - explains how to use the app -->
        <activity
            android:name=".Activities.HowToPlayActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Practice screen - lets user pick Trivia or Word Search -->
        <activity
            android:name=".Activities.PracticeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Trivia game screen -->
        <activity
            android:name=".Activities.TriviaActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Word Search game screen -->
        <activity
            android:name=".Activities.WordSearchActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Game history screen - shows all past Trivia and Word Search games -->
        <activity
            android:name=".Activities.GameHistoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Speed Trivia game screen - answer as many questions as possible in 60 seconds -->
        <activity
            android:name=".Activities.SpeedTriviaActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ==================== RECEIVERS ==================== -->

        <!-- ReminderReceiver - wakes up at 9:00 AM and sends notification if user hasn't opened app -->
        <receiver
            android:name=".Receivers.ReminderReceiver"
            android:exported="false" />

        <!-- BootReceiver - reschedules the daily alarm after phone restart -->
        <receiver
            android:name=".Receivers.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>


        <!-- FileProvider - lets us safely share camera photos with the camera app -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>