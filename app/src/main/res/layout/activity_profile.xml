<?xml version="1.0" encoding="utf-8"?>
<!-- Profile screen - shows the user's kingdom card -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B5E"
    android:fitsSystemWindows="true">

    <!-- Back arrow -->
    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textColor="#FFD700"
        android:textSize="16sp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👑 My Kingdom Card"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Profile picture with golden frame -->
            <!-- FrameLayout lets us stack views on top of each other -->
            <!-- The crown emoji sits on top of the profile picture -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">

                <!-- Profile picture - circular -->
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_gold_border"
                    android:padding="3dp" />

                <!-- Camera icon overlay - tapping opens image picker -->
                <TextView
                    android:id="@+id/tvChangePhoto"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="📷"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="#1A237E"
                    android:layout_gravity="bottom|end" />

            </FrameLayout>

            <!-- User name with edit button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <!-- Full name -->
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Edit name button -->
                <TextView
                    android:id="@+id/tvEditName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ✏️"
                    android:textSize="18sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Email - view only -->
            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#B0BEC5"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Title badge - changes based on words learned -->
            <TextView
                android:id="@+id/tvTitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱 Apprentice"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="#283593"
                android:padding="8dp"
                android:layout_marginTop="12dp" />

            <!-- Stats card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1A237E"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Stats title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 My Stats"
                        android:textColor="#FFD700"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Total words learned -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Total words learned"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvTotalWords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFD700"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Streak -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 Day streak"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 days"
                            android:textColor="#FFD700"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Progress ring label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 Overall progress"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Overall progress bar -->
                    <ProgressBar
                        android:id="@+id/progressOverall"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progressTint="#FFD700"
                        android:progressBackgroundTint="#283593"
                        android:max="100" />

                    <!-- Progress percentage text -->
                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:gravity="end"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Title levels guide card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1A237E"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Title Levels"
                        android:textColor="#FFD700"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="🌱 Apprentice — 0 to 20 words"
                        android:textColor="#B0BEC5" android:textSize="13sp" android:layout_marginBottom="6dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="⚔️ Knight — 21 to 50 words"
                        android:textColor="#B0BEC5" android:textSize="13sp" android:layout_marginBottom="6dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="🛡️ Warrior — 51 to 100 words"
                        android:textColor="#B0BEC5" android:textSize="13sp" android:layout_marginBottom="6dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="👑 Master — 101 to 200 words"
                        android:textColor="#B0BEC5" android:textSize="13sp" android:layout_marginBottom="6dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="🔥 Legend — 200+ words"
                        android:textColor="#B0BEC5" android:textSize="13sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>