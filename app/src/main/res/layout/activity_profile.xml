<?xml version="1.0" encoding="utf-8"?>
<!-- Profile screen - shows the user's kingdom card -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B5E"
    android:fitsSystemWindows="true">

    <!-- Back arrow -->
    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textColor="#FFD700"
        android:textSize="16sp"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👑 My Kingdom Card"
        android:textColor="#FFD700"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Profile picture with golden frame -->
            <!-- FrameLayout stacks the camera icon on top of the profile picture -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp">

                <!-- Profile picture - circular with gold border -->
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_gold_border"
                    android:padding="3dp" />

                <!-- Camera icon - tapping opens image picker to change photo -->
                <TextView
                    android:id="@+id/tvChangePhoto"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="📷"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="#1A237E"
                    android:layout_gravity="bottom|end" />

            </FrameLayout>

            <!-- User name with edit pencil button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <!-- Full name loaded from Firestore -->
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Tapping this opens the edit name dialog -->
                <TextView
                    android:id="@+id/tvEditName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ✏️"
                    android:textSize="18sp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Email - view only, cannot be changed -->
            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#B0BEC5"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Title badge - updates automatically based on total words learned -->
            <TextView
                android:id="@+id/tvTitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱 Apprentice"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="#283593"
                android:padding="8dp"
                android:layout_marginTop="12dp" />

            <!-- ===== MY STATS CARD ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1A237E"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 My Stats"
                        android:textColor="#FFD700"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Total words learned row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Total words learned"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp"
                            android:layout_weight="1" />

                        <!-- Updated in real time by loadTotalWordsLearned() -->
                        <TextView
                            android:id="@+id/tvTotalWords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFD700"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Day streak row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 Day streak"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp"
                            android:layout_weight="1" />

                        <!-- Updated by updateStreak() -->
                        <TextView
                            android:id="@+id/tvStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 days"
                            android:textColor="#FFD700"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Overall progress label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 Overall progress"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Progress bar - fills based on learned/total words ratio -->
                    <ProgressBar
                        android:id="@+id/progressOverall"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progressTint="#FFD700"
                        android:progressBackgroundTint="#283593"
                        android:max="100" />

                    <!-- Progress percentage shown to the right of the bar -->
                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:gravity="end"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== GAME STATS CARD ===== -->
            <!-- Shows best scores and times for Trivia and Word Search -->
            <!-- Loaded in real time by loadGameStats() in ProfileActivity -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1A237E"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎮 Game Stats"
                        android:textColor="#FFD700"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Trivia best score row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧠 Trivia best score"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp"
                            android:layout_weight="1" />

                        <!-- Shows "-" until user plays Trivia for the first time -->
                        <TextView
                            android:id="@+id/tvTriviaBestScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#FFD700"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Trivia best time row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱️ Trivia best time"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp"
                            android:layout_weight="1" />

                        <!-- Shows "-" until user plays Trivia for the first time -->
                        <TextView
                            android:id="@+id/tvTriviaBestTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#FFD700"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider line between Trivia and Word Search sections -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#283593"
                        android:layout_marginBottom="12dp" />

                    <!-- Word Search best time row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍 Word Search best time"
                            android:textColor="#B0BEC5"
                            android:textSize="14sp"
                            android:layout_weight="1" />

                        <!-- Shows "-" until user plays Word Search for the first time -->
                        <TextView
                            android:id="@+id/tvWordSearchBestTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#FFD700"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== TITLE LEVELS CARD ===== -->
            <!-- Shows the user what title they can earn and how many words are needed -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#1A237E"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Title Levels"
                        android:textColor="#FFD700"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Each row shows a title and how many words are needed to earn it -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🌱 Apprentice — 0 to 20 words"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚔️ Knight — 21 to 50 words"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🛡️ Warrior — 51 to 100 words"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="👑 Master — 101 to 200 words"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔥 Legend — 200+ words"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>