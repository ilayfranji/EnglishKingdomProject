<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A237E"
    tools:context=".Activities.LearnActivity">

    <!-- סרגל עליון -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- כפתור חזרה למסך הבית -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="28sp"
            android:textColor="#FFD700"
            android:padding="8dp"/>

        <!-- כותרת המסך -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Learn 📚"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:gravity="center"
            android:fontFamily="serif"/>

        <!-- לפני שהמנהל במצב עריכה מופיע לו על כפתור הfab סימן עריכה, כשהוא נלחץ הוא הופך להוספה, שוב רק המנהל רואה -->
        <TextView
            android:id="@+id/tvEditMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️"
            android:textSize="24sp"
            android:padding="8dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- הודעה שמופיעה למנהל כשהוא במצב עריכה -->
    <TextView
        android:id="@+id/tvEditBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="✏️ Edit Mode - Tap to edit, Long press to delete"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="#C62828"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ריסייקלר וויו, נותן למשתמש לגלול בין הקארד וויו של כל קטגוריה -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCategories"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvEditBanner"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- כפתור FAB floating action bar מאפשר להוסיף קטגוריות, רק המנהל רואה אותו -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#FFD700"
        app:tint="#1A237E"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- יציאה ממצב עריכה -רק מנהל רואה כפתור זה -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabExitEditMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_delete"
        app:backgroundTint="#C62828"
        app:tint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>