<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A237E"
    tools:context=".Activities.LearnActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="28sp"
            android:textColor="#FFD700"
            android:padding="8dp"/>

        <!-- Screen Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Learn 📚"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:gravity="center"
            android:fontFamily="serif"/>

        <!-- Edit Mode Button (FAB replacement in top bar) - only visible to admin -->
        <TextView
            android:id="@+id/tvEditMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️"
            android:textSize="24sp"
            android:padding="8dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Edit Mode Banner - shown when admin is in edit mode -->
    <TextView
        android:id="@+id/tvEditBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="✏️ Edit Mode - Tap to edit, Long press to delete"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="#C62828"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- RecyclerView - displays the list of category cards -->
    <!-- RecyclerView is an efficient way to display a scrollable list of items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCategories"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvEditBanner"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- FAB - Floating Action Button - only visible to admin -->
    <!-- FAB is a round button that floats above the content -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#FFD700"
        app:tint="#1A237E"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Exit Edit Mode Button - only visible when admin is in edit mode -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabExitEditMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_delete"
        app:backgroundTint="#C62828"
        app:tint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>