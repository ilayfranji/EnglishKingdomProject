<?xml version="1.0" encoding="utf-8"?>
<!-- This is the layout for the Add/Edit Category popup dialog -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1A237E">

    <!-- Category Name in English input -->
    <EditText
        android:id="@+id/etCategoryName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Category Name in English"
        android:textColorHint="#B0BEC5"
        android:textColor="#FFFFFF"
        android:inputType="textCapSentences"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- Category Name in Hebrew input -->
    <EditText
        android:id="@+id/etCategoryNameHebrew"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="שם הקטגוריה בעברית"
        android:textColorHint="#B0BEC5"
        android:textColor="#FFFFFF"
        android:inputType="textCapSentences"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- Image preview - shown after admin selects an image OR when editing existing category -->
    <!-- visibility="gone" means hidden by default - shown when image is selected -->
    <!-- adjustViewBounds=true keeps the original image proportions -->
    <!-- scaleType="fitCenter" shows full image without cropping -->
    <ImageView
        android:id="@+id/imgPreview"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:layout_marginBottom="8dp"
        android:visibility="gone"/>

    <!-- Add Image button - hidden after image is selected -->
    <Button
        android:id="@+id/btnAddImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📷 Add Image"
        android:textColor="#1A237E"
        android:backgroundTint="#FFD700"
        android:textStyle="bold"/>

</LinearLayout>