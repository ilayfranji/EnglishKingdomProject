<?xml version="1.0" encoding="utf-8"?>
<!-- תצוגה של קטגוריה אחת בודדת ברסייקלר וויו של הקטגוריות -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#283593"
    app:cardElevation="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- מציג את התמונה של הקטגוריה -->
        <ImageView
            android:id="@+id/imgCategory"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- שם הקטגוריה באנגלית -->
        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Animals"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/imgCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- כמות מילים שיש בקטגוריה הזאת -->
        <TextView
            android:id="@+id/tvWordCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 words"
            android:textSize="12sp"
            android:textColor="#7986CB"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryName"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- שם הקטגוריה בעברית -->
        <TextView
            android:id="@+id/tvCategoryNameHebrew"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="בעלי חיים"
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvWordCount"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- מד התקדמות, מציג כמה התקדמת בלימוד מכל קטגוריה -->
        <!-- מציג את זה בתור מד אופקי שמתמלא  -->
        <ProgressBar
            android:id="@+id/progressCategory"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:progress="0"
            android:max="100"
            android:progressTint="#FFD700"
            android:backgroundTint="#1A237E"
            app:layout_constraintTop_toBottomOf="@id/tvCategoryNameHebrew"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>