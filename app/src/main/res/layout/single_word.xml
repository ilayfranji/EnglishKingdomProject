<?xml version="1.0" encoding="utf-8"?>
<!-- This card is used for ALL types - words, letters, and sentences -->
<!-- WordAdapter shows/hides fields based on the category type -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="#1A237E"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Word image - only shown for WORDS type, hidden for LETTERS and SENTENCES -->
        <ImageView
            android:id="@+id/imgWord"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:contentDescription="Word image"
            android:visibility="gone" />

        <!-- Text content - takes all remaining space -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="4dp"
            android:gravity="center_vertical">

            <!-- English word / Letter name / English sentence -->
            <!-- Shown for ALL types but content changes based on type -->
            <TextView
                android:id="@+id/tvWordEnglish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Hebrew word / Hebrew explanation / Hebrew translation -->
            <!-- Shown for ALL types but content changes based on type -->
            <TextView
                android:id="@+id/tvWordHebrew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0BEC5"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Example sentence - only shown for WORDS type -->
            <!-- Hidden for LETTERS and SENTENCES types -->
            <TextView
                android:id="@+id/tvExampleSentence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7986CB"
                android:textSize="12sp"
                android:textStyle="italic"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Green checkmark - shown when this item is learned -->
        <!-- Visible for ALL types -->
        <TextView
            android:id="@+id/tvLearned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="24sp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>